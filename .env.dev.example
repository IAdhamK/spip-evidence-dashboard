APP_ENV=dev
DEV_APP_PORT=8081

LUMBUNG_HOST=https://lumbungfile.kemendesa.go.id
LUMBUNG_SHARE_TOKEN=isi-token-share-dev-atau-sama-untuk-readonly

DATABASE_PATH=data-dev/evidence-dev.db
SCAN_TIMEOUT_SECONDS=30
SCAN_MAX_DEPTH=4

LUMBUNG_MODE=test
LUMBUNG_REMOTE_ROOT=TEST_UPLOAD_SMART_EVIDENCE

SMART_UPLOAD_ENABLED=true
SMART_UPLOAD_ALLOW_REAL_UPLOAD=false
SMART_UPLOAD_REQUIRE_CONFIRMATION=true

AI_REASONING_ENABLED=true
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=isi-api-key-dev
DEEPSEEK_BASE_URL=https://api-gate-v2.sumopod.com
DEEPSEEK_MODEL=deepseek-v4-flash
AI_SEND_FULL_DOCUMENT=false
AI_MAX_CANDIDATES=5
AI_TIMEOUT_SECONDS=20
