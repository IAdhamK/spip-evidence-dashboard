LUMBUNG_HOST=https://lumbungfile.kemendesa.go.id
LUMBUNG_SHARE_TOKEN=
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
SCAN_TIMEOUT_SECONDS=30
AI_PROVIDER=sumopod
SUMOPOD_API_KEY=
DEEPSEEK_BASE_URL=https://ai.sumopod.com/v1
DEEPSEEK_CHAT_PATH=/chat/completions
DEEPSEEK_RESPONSES_PATH=/responses
DEEPSEEK_MODEL=deepseek-v4-pro
ANALYSIS_API_SURFACE=responses
ANALYSIS_RESPONSES_MAX_OUTPUT_TOKENS=4096
ANALYSIS_PIPELINE_V2_ENABLED=false
ANALYSIS_PIPELINE_V2_SHADOW=false
LEGACY_SMART_UPLOAD_ENABLED=true
VISION_ANALYSIS_ENABLED=false
VERIFICATION_PASS_ENABLED=true
ALLOW_PARTIAL_PRIMARY=false
ANALYSIS_PENDING_FILE_TTL_HOURS=72
# Local/non-container default remains SQLite BLOB for backward compatibility.
# Production Docker Compose defaults to filesystem under /app/data/analysis-payloads.
# To opt in outside Compose, uncomment and use a private, encrypted volume:
# ANALYSIS_PAYLOAD_STORAGE_BACKEND=filesystem
# ANALYSIS_PAYLOAD_STORAGE_PATH=data/analysis-payloads
# ANALYSIS_PAYLOAD_STORAGE_FSYNC=true
ANALYSIS_PAYLOAD_STORAGE_ENCRYPTION_VALIDATED=false
# Runtime/container paths. Both files must be private regular files; the evidence
# is bound to DATABASE_PATH, payload backend/path, and their device IDs.
ANALYSIS_STORAGE_ENCRYPTION_EVIDENCE_PATH=
ANALYSIS_STORAGE_ENCRYPTION_KEY_PATH=
ANALYSIS_WORKER_LIMIT=2
ANALYSIS_JOB_LEASE_MINUTES=15
ANALYSIS_JOB_HEARTBEAT_SECONDS=30
ANALYSIS_QUEUE_BACKEND=sqlite
# Redis is only a wake-up signal over shared PostgreSQL canonical state.
# Keep empty while DATABASE_PATH still points to SQLite. Production requires rediss://.
ANALYSIS_QUEUE_REDIS_URL=
ANALYSIS_QUEUE_REDIS_NAMESPACE=spip:analysis:v2
ANALYSIS_QUEUE_REDIS_CONNECT_TIMEOUT_SECONDS=2
ANALYSIS_QUEUE_REDIS_REQUIRE_TLS=true
ANALYSIS_EXPECTED_REPLICAS=1
ANALYSIS_WORKER_LEADER_LEASE_SECONDS=30
ANALYSIS_WORKER_LEADER_HEARTBEAT_SECONDS=10
ANALYSIS_PROMETHEUS_METRICS_ENABLED=true
# Alert when the rolling one-hour estimated model cost exceeds this positive budget.
ANALYSIS_COST_ALERT_USD_PER_HOUR=10.0
# Isi sesuai tarif kontrak provider. Nilai 0 tetap mencatat token tanpa mengarang biaya.
ANALYSIS_MODEL_INPUT_COST_PER_MILLION_USD=0.0
ANALYSIS_MODEL_OUTPUT_COST_PER_MILLION_USD=0.0
ANALYSIS_STRUCTURED_MODEL_ENABLED=false
ANALYSIS_MAPPING_REASONING_ENABLED=false
ANALYSIS_ADVANCED_RAG_ENABLED=false
ANALYSIS_ADVANCED_RAG_DEEPSEEK_ENABLED=false
ANALYSIS_ADVANCED_RAG_MIN_CONFIDENCE=0.68
ANALYSIS_ADVANCED_RAG_AMBIGUITY_MARGIN=0.08
ANALYSIS_DOCUMENT_FAMILY_MIN_CONFIDENCE=0.70
ANALYSIS_RELEVANT_COVERAGE_MIN_RATIO=0.70
ANALYSIS_MAPPING_AMBIGUITY_MARGIN=0.08
ANALYSIS_DECISION_CONFIDENCE_HIGH_THRESHOLD=0.80
ANALYSIS_MODEL_VERIFIER_ENABLED=false
ANALYSIS_MODEL_RETRY_ATTEMPTS=2
ANALYSIS_ROUTING_STRUCTURED_MIN_COMPLEXITY=0.25
ANALYSIS_ROUTING_MAPPING_MARGIN=0.08
ANALYSIS_ROUTING_VERIFIER_MIN_RISK=0.45
ANALYSIS_VISION_MAX_UNITS=12
ANALYSIS_PDF_RENDER_DPI=144
ANALYSIS_PDF_RETRY_RENDER_DPI=288
ANALYSIS_PDF_RETRY_MAX_UNITS=8
ANALYSIS_OFFICE_RENDERING_ENABLED=true
ANALYSIS_OFFICE_RENDER_MAX_PAGES=24
ANALYSIS_VISION_PROVIDER_VALIDATED=false
ANALYSIS_LOCAL_OCR_ENABLED=true
ANALYSIS_LOCAL_OCR_PROVIDER=auto
ANALYSIS_LOCAL_OCR_LANGUAGES=ind+eng
ANALYSIS_LOCAL_OCR_MIN_CONFIDENCE=0.45
ANALYSIS_LOCAL_OCR_TIMEOUT_SECONDS=30
ANALYSIS_LOCAL_OCR_UNIT_BUDGET_SECONDS=180
ANALYSIS_LOCAL_OCR_DOCUMENT_BUDGET_SECONDS=900
ANALYSIS_LOCAL_OCR_MAX_ATTEMPTS_PER_UNIT=24
ANALYSIS_LOCAL_OCR_RENDER_BATCH_UNITS=4
ANALYSIS_LOCAL_OCR_MAX_UNITS=100
ANALYSIS_LOCAL_OCR_TESSERACT_PSM_MODES=6,3,11
ANALYSIS_LOCAL_OCR_PREPROCESSING_ENABLED=true
ANALYSIS_LOCAL_OCR_MAX_IMAGE_PIXELS=16000000
ANALYSIS_LOCAL_OCR_MAX_TILES=16
ANALYSIS_ROLLOUT_STAGE=development
ANALYSIS_CANARY_PERCENTAGE=0
ANALYSIS_STABLE_RELEASE_CYCLES=0
ANALYSIS_REQUIRE_REVIEWER_IDENTITY=false
ANALYSIS_REVIEWER_IDENTITY_HEADER=X-Reviewer-Identity
ANALYSIS_REQUIRE_REVIEWER_ROLE=false
ANALYSIS_REVIEWER_ROLE_HEADER=X-Reviewer-Roles

# Docker Compose observability. Keep the local no-delivery config by default.
ALERTMANAGER_CONFIG_FILE=/etc/alertmanager/alertmanager.yml
# For production webhook delivery, set the config above to
# /etc/alertmanager/alertmanager.webhook.yml and provide an absolute host path:
# ALERTMANAGER_WEBHOOK_URL_FILE=/secure/path/alertmanager_webhook_url
ANALYSIS_MAX_REDIRECTS=3
ANALYSIS_BATCH_MAX_ARCHIVE_BYTES=268435456
ANALYSIS_BATCH_MAX_ENTRIES=2000
ANALYSIS_BATCH_MAX_FILES=200
ANALYSIS_BATCH_MAX_ENTRY_BYTES=67108864
ANALYSIS_BATCH_MAX_UNCOMPRESSED_BYTES=536870912
ANALYSIS_BATCH_MAX_COMPRESSION_RATIO=100
EVIDENCE_LINK_ALLOWED_HOSTS=docs.google.com,drive.google.com,googleusercontent.com
